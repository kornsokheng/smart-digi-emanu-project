PORT=3001
# Optional for production hosting with persistent disks.
# DATA_DIR=/var/data
# DB_PATH=/var/data/orders.db
# Bakong account ID (username) shown on the individual KHQR
BAKONG_ACCOUNT_USERNAME=your_account@devb
# JWT from https://api-bakong.nbc.gov.kh (required for /v1/check_transaction_by_md5)
BAKONG_MERCHANT_TOKEN=
# Optional: default https://api-bakong.nbc.gov.kh — use SIT for sandbox
# BAKONG_API_BASE_URL=https://api-bakong.nbc.gov.kh
BAKONG_USE_SIT=false
MERCHANT_DISPLAY_NAME=Merchant
MERCHANT_CITY=Phnom Penh
# USD or KHR (KHR amounts must be whole riels, no decimals)
BAKONG_QR_CURRENCY=USD
# Positive amount: USD allows cents (e.g. 1.50); KHR must be an integer (e.g. 4100)
BAKONG_QR_AMOUNT=1
# Tip: restart the API after changing these. `.env` is loaded from the project root (see server/index.js).
# Optional caps when clients send `amount` (e-menu checkout)
# MAX_ORDER_AMOUNT_KHR=5000000
# MIN_ORDER_AMOUNT_KHR=500

# Telegram bot integration
# Create/rotate token with BotFather and never commit real tokens.
TELEGRAM_BOT_TOKEN=
# Group ID like -100123...
TELEGRAM_BARISTA_GROUP_ID=
# Public HTTPS URL of the mini app frontend
TELEGRAM_MINI_APP_URL=
